{
  "name": "dep-up-surgeon",
  "version": "1.6.6",
  "description": "Upgrade npm dependencies one-by-one with validation, rollback, and conflict reporting.",
  "main": "dist/cli.js",
  "bin": {
    "dep-up-surgeon": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test test/unit/conflict-parser.test.mjs test/unit/npm-output-samples.test.mjs test/fixtures-runner.mjs",
    "test:unit": "npm run build && node --test test/unit/conflict-parser.test.mjs test/unit/npm-output-samples.test.mjs",
    "test:fixtures": "npm run build && node --test test/fixtures-runner.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexlibe95/dep-up-surgeon.git"
  },
  "keywords": [
    "npm",
    "dependencies",
    "upgrade",
    "cli",
    "semver"
  ],
  "author": "Alexandros Lymperopoulos",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/alexlibe95/dep-up-surgeon/issues"
  },
  "homepage": "https://dep-up-surgeon.netlify.app/",
  "engines": {
    "node": "^20.17.0 || >=22.9.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "11.3.4",
    "pacote": "21.5.0",
    "prompts": "^2.4.2",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "25.6.0",
    "@types/prompts": "^2.4.9",
    "@types/semver": "7.7.1",
    "typescript": "6.0.2"
  }
}
